# Lumenfield environment variables
# Copy to .env.local for local development.
# Add the same keys in Vercel: Project > Settings > Environment Variables.

# AI providers
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
FAL_KEY=
ELEVENLABS_API_KEY=
RUNWAY_API_KEY=
KLING_API_KEY=

# Auth providers
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_CREDITS=
STRIPE_PRICE_PRO_CREDITS=
STRIPE_PRICE_ULTRA_CREDITS=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ULTRA_MONTHLY=

# Storage
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=lumenfield-media
CLOUDFLARE_R2_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=lumenfield-media

# App config
NEXT_PUBLIC_APP_URL=https://novaframe-ruddy.vercel.app
NEXT_PUBLIC_APP_NAME=Lumenfield
